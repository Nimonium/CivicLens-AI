                        <span class="material-symbols-outlined text-outline-variant">stars</span>
                    </div>
                </div>
            </div>
        </section>
        <!-- Monthly Resolution Rate (Line Chart Area) -->
        <section class="bg-surface-container-lowest p-lg rounded-xl shadow-sm border border-outline-variant">
            <div class="flex flex-col md:flex-row md:items-center justify-between mb-lg gap-4">
                <div>
                    <h3 class="font-headline-sm text-headline-sm text-on-surface">Monthly Resolution Rate</h3>
                    <p class="font-label-md text-label-md text-on-surface-variant">Track the efficiency of response
