                            style="height: 90px;"></div>
                        <span class="font-label-md text-label-md text-on-surface-variant">Waste</span>
                    </div>
                    <div class="flex flex-col items-center gap-2 z-10 w-full">
                        <div class="w-12 bg-primary rounded-t-lg chart-bar hover:opacity-80 transition-opacity"
                            style="height: 210px;"></div>
                        <span class="font-label-md text-label-md text-on-surface-variant">Safety</span>
                    </div>
