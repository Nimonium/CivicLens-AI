<body class="text-on-surface pb-24 md:pb-0">
    <!-- TopAppBar Navigation -->
    <header class="bg-surface dark:bg-on-background shadow-sm fixed top-0 w-full z-50">
        <div class="hidden md:flex justify-between items-center px-lg w-full max-w-7xl mx-auto h-16">
            <div class="flex items-center gap-3">
                <span
                    class="material-symbols-outlined text-primary dark:text-primary-fixed text-3xl">volunteer_activism</span>
                <h1 class="font-headline-md text-headline-md font-bold text-primary dark:text-primary-fixed">Community
                    Hero</h1>
            </div>
            <nav class="flex gap-8">
                <a class="font-label-md text-label-md text-primary dark:text-primary-fixed border-b-2 border-primary py-5"
                    href="#">Home</a>
                <a class="font-label-md text-label-md text-on-surface-variant dark:text-outline-variant hover:bg-surface-container-high dark:hover:bg-on-surface-variant transition-colors py-5 px-2"
                    href="#">Map</a>
                <a class="font-label-md text-label-md text-on-surface-variant dark:text-outline-variant hover:bg-surface-container-high dark:hover:bg-on-surface-variant transition-colors py-5 px-2"
                    href="#">Report</a>
                <a class="font-label-md text-label-md text-on-surface-variant dark:text-outline-variant hover:bg-surface-container-high dark:hover:bg-on-surface-variant transition-colors py-5 px-2"
                    href="#">Feed</a>
                <a class="font-label-md text-label-md text-on-surface-variant dark:text-outline-variant hover:bg-surface-container-high dark:hover:bg-on-surface-variant transition-colors py-5 px-2"
                    href="#">Profile</a>
            </nav>
            <div class="flex items-center gap-4">
                <button
                    class="material-symbols-outlined text-on-surface-variant p-2 rounded-full hover:bg-surface-container-high transition-colors">search</button>
                <div
                    class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-bold text-xs">
                    CH</div>
            </div>
        </div>
        <!-- Mobile Top Bar -->
        <div class="md:hidden flex justify-between items-center px-gutter h-14 bg-surface shadow-sm">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-2xl">volunteer_activism</span>
                <span class="font-headline-sm-mobile text-headline-sm-mobile font-bold text-primary">Community
                    Hero</span>
            </div>
            <span class="material-symbols-outlined text-on-surface-variant">search</span>
        </div>
    </header>
    <main class="max-w-7xl mx-auto px-gutter pt-20 md:pt-24 space-y-xl pb-10">
        <!-- Header & Top Metrics -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
            <div class="lg:col-span-2 flex flex-col justify-center">
                <h2
                    class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-2">
                    Impact Dashboard</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">Real-time transparency on community
                    improvements and civic engagement across our city.</p>
            </div>
            <!-- Average Resolve Time Metric -->
            <div
                class="bg-surface-container-lowest p-md rounded-xl shadow-sm border border-outline-variant flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-primary-fixed flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary"
                        style="font-variation-settings: 'FILL' 1;">timer</span>
                </div>
                <div>
                    <p class="font-label-md text-label-md text-on-surface-variant">Average Resolve Time</p>
                    <p class="font-headline-sm text-headline-sm text-on-surface">4.2 days</p>
                </div>
            </div>
            <!-- Citizen Satisfaction Metric -->
            <div
                class="bg-surface-container-lowest p-md rounded-xl shadow-sm border border-outline-variant flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center">
                    <span class="material-symbols-outlined text-secondary"
                        style="font-variation-settings: 'FILL' 1;">sentiment_satisfied</span>
                </div>
                <div>
                    <p class="font-label-md text-label-md text-on-surface-variant">Citizen Satisfaction</p>
                    <p class="font-headline-sm text-headline-sm text-on-surface">85%</p>
                </div>
            </div>
        </section>
        <!-- Bento Grid Charts & Lists -->
