                </div>
                <div class="h-64 flex items-end justify-between px-4 pb-8 relative">
                    <!-- Grid Lines -->
                    <div class="absolute inset-x-0 top-0 bottom-8 flex flex-col justify-between pointer-events-none">
                        <div class="border-t border-outline-variant w-full opacity-30"></div>
                        <div class="border-t border-outline-variant w-full opacity-30"></div>
                        <div class="border-t border-outline-variant w-full opacity-30"></div>
                        <div class="border-t border-outline-variant w-full opacity-30"></div>
